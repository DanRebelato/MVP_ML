      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Tipo de problema: classificacao\n",
            "Target: Class\n",
            "Número de features: 30\n",
            "  Componentes PCA (V1–V28): 28 | Amount: 1 | Hour_of_Day: 1\n",
            "Shape de X: (284807, 30) | Shape de y: (284807,)\n"
