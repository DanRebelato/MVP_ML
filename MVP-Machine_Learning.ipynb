      "source": [
        "# ─── Distribuição da variável-alvo\n",
        "TARGET = 'Class'\n",
        "\n",
        "class_counts = df[TARGET].value_counts()\n",
        "class_pct    = df[TARGET].value_counts(normalize=True) * 100\n",
        "\n",
        "summary = pd.DataFrame({'Contagem': class_counts, 'Percentual (%)': class_pct.round(4)})\n",
        "summary.index = ['Legítima (0)', 'Fraude (1)']\n",
        "print('=== Distribuição da Variável-Alvo (Class) ===')\n",
        "print(summary.to_string())\n",
        "\n",
        "fig, axes = plt.subplots(1, 2, figsize=(12, 4))\n",
        "\n",
        "axes[0].bar(['Legítima (0)', 'Fraude (1)'], class_counts, color=['#4C72B0', '#DD8452'], edgecolor='white')\n",
        "axes[0].set_title('Contagem por Classe', fontsize=13, fontweight='bold')\n",
        "axes[0].set_ylabel('Nº de Transações')\n",
        "for i, v in enumerate(class_counts):\n",
        "    axes[0].text(i, v + 1000, f'{v:,}', ha='center', fontsize=11)\n",
        "\n",
        "axes[1].pie(class_counts, labels=['Legítima (0)', 'Fraude (1)'],\n",
        "            autopct='%1.3f%%', colors=['#4C72B0', '#DD8452'],\n",
        "            startangle=90, wedgeprops=dict(edgecolor='white', linewidth=1.5))\n",
        "axes[1].set_title('Proporção por Classe', fontsize=13, fontweight='bold')\n",
        "\n",
        "plt.suptitle('Desbalanceamento de Classes', fontsize=15, fontweight='bold', y=1.02)\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "print(f'\\n Razão de desbalanceamento: 1:{int(class_counts[0]/class_counts[1])} (legítima:fraude)')\n"
      ],
      "id": "v37iOj4O51CL"
    },
