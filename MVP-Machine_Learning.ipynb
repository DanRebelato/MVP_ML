      "source": [
        "## 2.1 Funções auxiliares\n"
      ],
      "id": "EOwwXbg451CK"
    },
    {
      "cell_type": "code",
      "execution_count": 29,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "XZ0XJvgW51CK",
        "outputId": "40ab116e-87b4-4b9d-dc44-10f226973ffc"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Funções auxiliares definidas.\n"
          ]
        }
      ],
      "source": [
        "# Treinamento do modelo e retorno do dicionário com as métricas principais.\n",
        "def evaluate_model(name, model, X_tr, y_tr, X_te, y_te):\n",
        "    t0 = time.time()\n",
        "    model.fit(X_tr, y_tr)\n",
        "    train_time = time.time() - t0\n",
        "\n",
        "    y_pred  = model.predict(X_te)\n",
        "    y_proba = model.predict_proba(X_te)[:, 1]\n",
        "\n",
        "    return {\n",
        "        'Model':        name,\n",
        "        'Recall':       recall_score(y_te, y_pred),\n",
        "        'Precision':    precision_score(y_te, y_pred, zero_division=0),\n",
        "        'F1':           f1_score(y_te, y_pred),\n",
        "        'AUC-ROC':      roc_auc_score(y_te, y_proba),\n",
        "        'AUC-PR':       average_precision_score(y_te, y_proba),\n",
        "        'Train_time_s': round(train_time, 1),\n",
        "        'pipeline':     model,\n",
        "        'y_pred':       y_pred,\n",
        "        'y_proba':      y_proba\n",
        "    }\n",
        "\n",
        "# Exibição dos resultados como DataFrame estilizado\n",
        "def show_results_table(results_list, cols=None):\n",
        "\n",
        "    if cols is None:\n",
        "        cols = ['Model', 'Recall', 'Precision', 'F1', 'AUC-ROC', 'AUC-PR', 'Train_time_s']\n",
        "    df_r = pd.DataFrame([{k: r[k] for k in cols} for r in results_list]).set_index('Model')\n",
        "    return df_r.style \\\n",
        "        .highlight_max(subset=['Recall','Precision','F1','AUC-ROC','AUC-PR'], color='#c6efce') \\\n",
        "        .highlight_min(subset=['Train_time_s'], color='#c6efce') \\\n",
        "        .format({'Recall':'{:.4f}','Precision':'{:.4f}','F1':'{:.4f}',\n",
        "                 'AUC-ROC':'{:.4f}','AUC-PR':'{:.4f}','Train_time_s':'{:.1f}s'})\n",
        "\n",
        "\n",
        "print('Funções auxiliares definidas.')\n"
      ],
      "id": "XZ0XJvgW51CK"
    },
