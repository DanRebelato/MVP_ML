        }
      ],
      "source": [
        "# ─── Engenharia de features\n",
        "# Hora do dia a partir de Time (segundos → horas → módulo 24)\n",
        "df['Hour_of_Day'] = (df['Time'] / 3600) % 24\n",
        "\n",
        "# ─── Separação de features e target\n",
        "columns_to_exclude = set(ID_COLUMNS + DROP_COLUMNS + [TARGET])\n",
        "FEATURES = [c for c in df.columns if c not in columns_to_exclude]\n",
        "\n",
        "X = df[FEATURES].copy()\n",
        "y = df[TARGET].copy()\n",
        "\n",
        "print(f'Tipo de problema: {PROBLEM_TYPE}')\n",
        "print(f'Target: {TARGET}')\n",
        "print(f'Número de features: {len(FEATURES)}')\n",
        "print(f'  Componentes PCA (V1–V28): 28 | Amount: 1 | Hour_of_Day: 1')\n",
        "print(f'Shape de X: {X.shape} | Shape de y: {y.shape}')\n"
      ],
      "id": "fH4gJiBp51CM"
    },
    {
      "cell_type": "code",
      "execution_count": 40,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "pUb-zsZZ51CM",
        "outputId": "2c9012ae-1c34-4211-8f25-180a852e968a"
      },
      "outputs": [
